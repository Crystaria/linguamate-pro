# LinguaMate Pro 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# OpenAI API 配置（可选，用于切换到真实 AI）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# DeepSeek API 配置（可选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Tesseract OCR 配置（Windows 用户需要）
# Windows 示例：TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
# Linux/Mac 通常不需要配置
TESSERACT_CMD=

# AI 模式选择：local（本地模拟）| openai | deepseek
AI_MODE=local

# 前端配置（可选）
REACT_APP_API_URL=http://localhost:8000
REACT_APP_DEMO_MODE=true
